              "value": {
                "value": "@activity('Get Lakehouse Task Info').output.firstRow.HighWatermarkValue",
                "type": "Expression"
              },
              "type": "string"
            }
          },
          "sessionTag": {
            "value": "@if(         not(empty(pipeline().parameters.GoldJobName)),     concat('gold_',        replace(             replace(pipeline().parameters.GoldJobName, ' ', '_'),             '-', '_'         )),     concat('gold_manualtaskkeylist') )",
            "type": "Expression"
          }
        }
