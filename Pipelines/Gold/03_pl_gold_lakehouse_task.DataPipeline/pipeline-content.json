      {
        "name": "If IsWatermarkEnabledFlag",
        "type": "IfCondition",
        "dependsOn": [
          {
            "activity": "Run Gold Notebook",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "typeProperties": {
          "expression": {
            "value": "@and(\n    equals(activity('Get Lakehouse Task Info').output.firstRow.IsWatermarkEnabledFlag, true),\n    equals(json(activity('Run Gold Notebook').output.result.exitValue).HasWatermarkUpdate, true)\n)",
            "type": "Expression"
          },
          "ifFalseActivities": [],
          "ifTrueActivities": [
            {
              "name": "Update Watermark",
              "type": "SqlServerStoredProcedure",
              "dependsOn": [],
              "policy": {
                "timeout": "0.12:00:00",
                "retry": 0,
                "retryIntervalInSeconds": 30,
                "secureOutput": false,
                "secureInput": false
              },
              "typeProperties": {
                "storedProcedureName": "[gold].[UpdateWatermarkValue]",
                "storedProcedureParameters": {
                  "IsWatermarkEnabledFlag": {
                    "value": {
                      "value": "@activity('Get Lakehouse Task Info').output.firstRow.IsWatermarkEnabledFlag",
                      "type": "Expression"
                    },
                    "type": "Boolean"
                  },
                  "NewHighWatermarkValue": {
                    "value": {
                      "value": "@json(activity('Run Gold Notebook').output.result.exitValue).NewHighWatermarkValue",
                      "type": "Expression"
                    },
                    "type": "Datetime"
                  },
                  "TaskKey": {
                    "value": {
                      "value": "@activity('Get Lakehouse Task Info').output.firstRow.TaskKey",
                      "type": "Expression"
                    },
                    "type": "Int64"
                  }
                }
              },
              "connectionSettings": {
                "name": "f18a49c7_7290_404e_8e0c_6963b0df7a07",
                "properties": {
                  "annotations": [],
                  "type": "FabricSqlDatabase",
                  "typeProperties": {
                    "workspaceId": "@pipeline().libraryVariables.vl_etlControl_etlControl_ws_id",
                    "artifactId": "@pipeline().libraryVariables.vl_etlControl_etlControl_db_id"
                  },
                  "externalReferences": {
                    "connection": "@pipeline().libraryVariables.vl_etlControl_etlControl_fabricsql_item_connection_id"
                  }
                }
              }
            }
          ]
        }
