            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "policy": {
          "timeout": "0.12:00:00",
          "retry": 0,
          "retryIntervalInSeconds": 30,
          "secureOutput": false,
          "secureInput": false
        },
        "typeProperties": {
          "notebookId": {
            "value": "@activity('Get Lakehouse Task Info').output.firstRow.NotebookID",
            "type": "Expression"
          },
          "workspaceId": {
            "value": "@pipeline().libraryVariables.vl_etlControl_etlControl_ws_id",
            "type": "Expression"
          },
          "parameters": {
            "TaskKey": {
              "value": {
                "value": "@activity('Get Lakehouse Task Info').output.firstRow.TaskKey",
                "type": "Expression"
              },
              "type": "int"
            },
            "TaskName": {
              "value": {
                "value": "@activity('Get Lakehouse Task Info').output.firstRow.TaskName",
                "type": "Expression"
              },
              "type": "string"
