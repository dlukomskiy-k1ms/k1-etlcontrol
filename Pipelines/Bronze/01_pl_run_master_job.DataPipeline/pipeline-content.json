            "type": "PipelineReference"
          },
          "parameters": {
            "JobName": {
              "value": "@pipeline().parameters.JobName",
              "type": "Expression"
            },
            "etlLoadDateTime": {
              "value": "@variables('etlLoadDateTime')",
